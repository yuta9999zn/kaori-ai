# =============================================================
# Kaori System — Environment Template
# ⚠️ DO NOT PUT REAL SECRETS HERE
# Copy this file to .env and fill values locally
# =============================================================

# ---- PostgreSQL ----
POSTGRES_PASSWORD=<SECRET>

# ---- JWT (RS256 key pair, base64-encoded PEM, single line) ----
# After copying this file to .env, generate a keypair with:
#   ./scripts/generate-jwt-keys.sh
# (The script edits .env in place. Re-run with --force to rotate keys.)
JWT_PRIVATE_KEY=<BASE64_ENCODED_PRIVATE_KEY>
JWT_PUBLIC_KEY=<BASE64_ENCODED_PUBLIC_KEY>
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ---- MFA Key (AES-256 encryption of TOTP secrets at rest) ----
# Required when SPRING_PROFILES_ACTIVE includes 'prod' or 'production' —
# auth-service refuses to start otherwise. Optional in dev: a deterministic
# dev key is used and a WARN is logged at startup.
# Generate with:
#   ./scripts/generate-mfa-key.sh             # writes to .env in place
#   # or:  openssl rand -base64 32
# Must be Base64 of exactly 32 bytes (AES-256). Rotation procedure:
# see CLAUDE.md §15 "MFA Key Management".
KAORI_MFA_KEY=<BASE64_32_BYTES>

# ---- Spring profiles ----
# Set to 'production' (or 'prod') to enforce production guards
# (e.g. KAORI_MFA_KEY required, dev fallbacks disabled).
SPRING_PROFILES_ACTIVE=

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
CORS_ALLOW_ORIGINS=http://localhost:3000

# ---- Rate Limiting ----
RATE_LIMIT_JWT_PER_MIN=60
RATE_LIMIT_IP_PER_MIN=300

# ---- Email ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<YOUR_EMAIL>
SMTP_PASSWORD=<SECRET>

# ---- LLM (Local default) ----
# Pilot/dev default: 7b (~5 GB RAM). Production: 14b (~10 GB RAM, ~80-85% better
# Vietnamese narrative quality but needs 24+ GB system RAM with full stack).
OLLAMA_MODEL=qwen2.5:7b

# ---- External AI ----
EXTERNAL_AI_ENABLED=false
ANTHROPIC_API_KEY=<SECRET>
OPENAI_API_KEY=<SECRET>
GOOGLE_API_KEY=<SECRET>

# ---- File Upload ----
UPLOAD_MAX_SIZE_MB=100
UPLOAD_MAX_TOTAL_MB=500

# ---- Observability ----
GRAFANA_USER=admin
GRAFANA_PASSWORD=<SECRET>
LOG_LEVEL=INFO

# ---- Database (legacy ETL) ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kaori
DB_USER=kaori_user
DB_PASSWORD=<SECRET>

# ---- Zalo Bot ----
ZALO_ACCESS_TOKEN=<SECRET>
ZALO_GROUP_ID=<GROUP_ID>
REPORT_RECIPIENTS=<EMAIL_LIST>

# ---- Data directories ----
NB_DATA_DIR=<PATH>
RJ_DATA_DIR=<PATH>

# ---- Report settings ----
REPORT_SEND_METHOD=zalo
NB_BEP_DAILY=10000000
RJ_BAR_BEP_DAILY=7000000
BAR_MINI_BEP_DAILY=4000000
# ---- P2-AUTH-001 SSO (Google OAuth 2.0) ----
# Get from Google Cloud Console → APIs & Services → Credentials.
# Redirect URI must be registered in the OAuth client config:
#   http://localhost:8080/api/v1/p2/auth/sso/google/callback  (dev)
#   https://app.kaori.ai/api/v1/p2/auth/sso/google/callback   (prod)
GOOGLE_CLIENT_ID=<SECRET>
GOOGLE_CLIENT_SECRET=<SECRET>
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/p2/auth/sso/google/callback

# ---- P2-AUTH-001 SSO (Microsoft Entra ID) ----
# Get from Microsoft Entra → App registrations → Certificates & secrets.
# Requires M365 Developer Program tenant (free, ~10 min) or paid Azure
# subscription.
#
# MICROSOFT_TENANT_ID is OPTIONAL:
#   - Empty / unset → multi-tenant "common" authority (recommended for
#     dev — accepts any Entra ID tenant + personal Microsoft accounts).
#   - Set to tenant GUID → single-tenant strict (prod hardening).
MICROSOFT_CLIENT_ID=<SECRET>
MICROSOFT_CLIENT_SECRET=<SECRET>
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=http://localhost:8080/api/v1/p2/auth/sso/microsoft/callback

# ---- P2-AUTH-001 SSO internal handoff ----
# Shared secret between ai-orchestrator and auth-service Java for the
# /sso/exchange-info endpoint. Set the SAME value in both services'
# env files. Rotate via Vault path platform/auth/internal_service_token
# Phase 2.5+ per K-18.
KAORI_INTERNAL_SVC_TOKEN=<SECRET>

# ---- Knowledge grounding / |OR| coverage gate (ADR-0033 "học 1 hiểu 10") ----
# Tunable, never hardcoded. All optional — defaults are sane for bge-m3.
# COVERAGE_K: saturation rate of coverage = 1-exp(-K*mass).
# GEN_MIN / GEN_CAUTION: coverage bands → "đủ" / "thận trọng" / "chưa đủ".
# SIM_FLOOR: per-citation cosine floor for the agent grounding gate. top-K
#   retrieval always returns K docs, so an off-domain query still yields K
#   weak (~0.25) hits; citations BELOW the floor contribute no coverage mass
#   so the decline branch fires (anti-hallucination, K-3). bge-m3 gives a
#   ~0.23 same-language floor; 0.35 keeps moderate+ hits, drops noise.
KAORI_KB_COVERAGE_K=0.6
KAORI_KB_GEN_MIN=0.60
KAORI_KB_GEN_CAUTION=0.30
KAORI_KB_SIM_FLOOR=0.35

# ---- Agent session→memory consolidation (RAG×harness step 3, IF-grows) ----
# A completed agent session is consolidated into an OPERATIONAL L3 memory that
# embeds the original question + grounding evidence, so recall_memory surfaces
# it on a FUTURE similar question. These cap the stored content (tunable).
KAORI_MEM_CONSOLIDATE_INTENT_LEN=200
KAORI_MEM_CONSOLIDATE_MAX_EVIDENCE=3
KAORI_MEM_CONSOLIDATE_SNIPPET_LEN=160
# Relevance floor (token-set Jaccard 0-1) for recall_memory. A weak lexical
# overlap (shared stopwords between an off-domain query and a memory) must not
# recall it and inflate the |OR| gate's memory mass. ~0.18 for a relevant
# recall, ~0 off-domain → 0.1 separates them.
KAORI_MEM_RECALL_FLOOR=0.1

<?xml version="1.0" encoding="UTF-8"?>
<!--
  P1-S1 (OBS-012) — Logback config with profile-aware appender:
    • dev (default + 'dev' profile) — colored text pattern matching the
      previous Spring Boot default. Easier to read in IntelliJ / terminal.
    • json (selected via SPRING_PROFILES_ACTIVE=json or prod/staging
      enabling include) — one JSON line per record using
      logstash-logback-encoder. Loki ingests these directly.

  Both appenders pull traceId + spanId + service.name from MDC. Spring Boot
  Tracing autoconfig writes traceId/spanId; service.name is set as a
  static field on the JSON encoder so every line carries the OTel
  resource attribute identity (K-19).

  tenant_id integration is scheduled for P1-S2 alongside the OTel SDK
  upgrade — once a JWT-aware MDC filter lands, the encoder's
  includeMdcKeyName list will pick it up automatically (no config
  change needed here).
-->
<configuration>

  <springProperty scope="context" name="serviceName"
                  source="spring.application.name" defaultValue="kaori-auth-service"/>

  <!-- Dev / local: colored text. Inherits Spring Boot's default but
       adds the trace correlation suffix ([service,trace,span]) so a
       grep against logs still pivots to Tempo. -->
  <springProfile name="!json">
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} %-5level [${serviceName},%X{traceId:-},%X{spanId:-}] %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>
    <root level="${LOG_LEVEL:-INFO}">
      <appender-ref ref="CONSOLE"/>
    </root>
  </springProfile>

  <!-- json profile (prod / staging / explicit local debug):
       structured JSON via logstash-logback-encoder. Loki indexes
       service.name + level + traceId labels for fast queries. -->
  <springProfile name="json">
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
        <providers>
          <timestamp>
            <fieldName>@timestamp</fieldName>
            <timeZone>UTC</timeZone>
          </timestamp>
          <version/>
          <pattern>
            <pattern>
              {
                "service.name": "${serviceName}",
                "level": "%level",
                "logger": "%logger",
                "thread": "%thread",
                "message": "%message",
                "traceId": "%mdc{traceId}",
                "spanId": "%mdc{spanId}"
              }
            </pattern>
          </pattern>
          <mdc>
            <!-- catch-all: any MDC key written downstream (tenant_id when
                 P1-S2 lands, request_id, session_id, etc.) is included
                 automatically without config changes here. -->
            <excludeMdcKeyName>traceId</excludeMdcKeyName>
            <excludeMdcKeyName>spanId</excludeMdcKeyName>
          </mdc>
          <stackTrace>
            <fieldName>stack_trace</fieldName>
            <throwableConverter class="net.logstash.logback.stacktrace.ShortenedThrowableConverter">
              <maxDepthPerThrowable>30</maxDepthPerThrowable>
              <rootCauseFirst>true</rootCauseFirst>
            </throwableConverter>
          </stackTrace>
        </providers>
      </encoder>
    </appender>
    <root level="${LOG_LEVEL:-INFO}">
      <appender-ref ref="JSON_CONSOLE"/>
    </root>
  </springProfile>

</configuration>

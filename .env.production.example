# .env.production.example — single-host (EC2 / VPS) production profile.
#
#   cp .env.production.example .env.production
#   # fill every CHANGE_ME, then:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up -d
#
# For EKS these values live in AWS Secrets Manager / the Helm shared Secret
# instead (see infrastructure/k8s + docs/runbooks/aws-eks-readiness.md).
# NEVER commit the filled .env.production — it is gitignored.

# ---- Profile ----------------------------------------------------------
# production = crypto/MFA/field-key resolution refuses dev fallbacks (K-18).
KAORI_PROFILE=production
SPRING_PROFILES_ACTIVE=production,json
LOG_LEVEL=INFO

# ---- Datastore passwords ----------------------------------------------
POSTGRES_PASSWORD=CHANGE_ME_strong_superuser_pw
KAORI_APP_PASSWORD=CHANGE_ME_strong_app_pw
# Flyway (DDL) uses the superuser; runtime app uses kaori_app.
SPRING_FLYWAY_USER=kaori
SPRING_FLYWAY_PASSWORD=CHANGE_ME_strong_superuser_pw
# Prod runs migrations forward-only — no repair, validate on.
SPRING_FLYWAY_REPAIR_ON_MIGRATE=false
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=true

# ---- JWT (RS256) — generate a keypair, paste PEM (newlines as \n) ------
#   openssl genrsa -out jwt.key 2048 && openssl rsa -in jwt.key -pubout -out jwt.pub
JWT_PRIVATE_KEY=CHANGE_ME_rsa_private_pem
JWT_PUBLIC_KEY=CHANGE_ME_rsa_public_pem
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# ---- Platform secrets --------------------------------------------------
# AES-256 master key for TOTP/field encryption (CLAUDE.md §15).
#   openssl rand -base64 32
KAORI_MFA_KEY=CHANGE_ME_base64_32B
# Shared secret between auth-service and ai-orchestrator (SSO handshake).
KAORI_INTERNAL_SVC_TOKEN=CHANGE_ME_random_token
# Vault: production should point at a real Vault, not the dev server.
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=CHANGE_ME_vault_token

# ---- Public URLs / CORS (domain, not localhost) -----------------------
FRONTEND_URL=https://CHANGE_ME.example.com
NEXT_PUBLIC_API_URL=https://api.CHANGE_ME.example.com
CORS_ALLOW_ORIGINS=https://CHANGE_ME.example.com
KAORI_ORCHESTRATOR_BASE_URL=http://ai-orchestrator:8093

# ---- LLM ---------------------------------------------------------------
# Qwen stays default (K-4). 7b fits a non-GPU VM; 14b needs a GPU host.
OLLAMA_MODEL=qwen2.5:7b
KAORI_NARRATIVE_MAX_TOKENS=400
SCHEMA_LLM_FALLBACK=1
# External vendor path OFF unless a tenant opts in with consent.
EXTERNAL_AI_ENABLED=false
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Blob store --------------------------------------------------------
# local = named docker volume (single host). Set to s3 + S3_* for AWS.
BLOB_STORE_BACKEND=local
UPLOAD_MAX_SIZE_MB=100

# ---- SMTP (notification-service) --------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME@example.com
SMTP_PASSWORD=CHANGE_ME_app_password
OUTBOX_POLL_ENABLED=true
OUTBOX_POLL_INTERVAL_SECONDS=5
OUTBOX_BATCH_SIZE=10

# ---- Rate limits (gateway) --------------------------------------------
RATE_LIMIT_JWT_PER_MIN=60
RATE_LIMIT_IP_PER_MIN=300

# ---- SSO (optional — leave blank to disable a provider) ---------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.CHANGE_ME.example.com/api/v1/p2/auth/sso/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=https://api.CHANGE_ME.example.com/api/v1/p2/auth/sso/microsoft/callback

# ---- Observability (Grafana admin) ------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME

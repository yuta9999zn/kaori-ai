*.sql.gz
*.dump
pg_backup_*/

# ─── Docker local state ─────────────────────────────────────────────
.docker/
volumes/

# ─── OS files ───────────────────────────────────────────────────────
desktop.ini
$RECYCLE.BIN/

# Generated extracts from product docs (regenerate via scripts/extract_product_docs.py)
docs/product/_extracted/

# Kaggle / external reference datasets — pull via scripts/, not source of truth
data/kaggle/
data/anphu/

# CodeGraph MCP index — local-per-machine knowledge graph (~55MB SQLite + WAL).
# Rebuild via `codegraph init`. Never commit; the index lags writes and is
# machine-specific. (.codegraph/ ships its own .gitignore for the .db files,
# but ignoring the dir at root keeps it out of `git status` entirely.)
.codegraph/

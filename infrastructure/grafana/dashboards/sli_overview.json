{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "datasource", "uid": "grafana"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "OBS-020 — SLI overview per service. Success rate, p95 latency, RPS, error rate. Phase 1.5 baseline panels; the SLO_burn dashboard layers the burn-rate views on top.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {"color": "red",    "value": null},
              {"color": "yellow", "value": 95},
              {"color": "green",  "value": 99.5}
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [
        {
          "expr": "(sum(rate(http_server_requests_seconds_count{status!~\"5..\"}[5m])) by (service) / sum(rate(http_server_requests_seconds_count[5m])) by (service)) * 100",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "title": "SLI — Success rate per service (5m)",
      "type": "stat",
      "options": {
        "colorMode": "value",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["last"], "fields": "", "values": false}
      }
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red",    "value": 1000}
            ]
          }
        }
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket[5m])) by (service, le)) * 1000",
          "refId": "A",
          "legendFormat": "p95 {{service}}"
        }
      ],
      "title": "SLI — p95 request latency per service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      },
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 6},
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count[1m])) by (service)",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "title": "RPS per service (1m)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green",  "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red",    "value": 0.05}
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 6},
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])) by (service) / sum(rate(http_server_requests_seconds_count[5m])) by (service)",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ],
      "title": "Error rate (5xx / total)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short"}
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 12},
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(kaori_ai_calls_total[5m])) by (model, status)",
          "refId": "A",
          "legendFormat": "{{model}} ({{status}})"
        }
      ],
      "title": "LLM dispatch — calls/sec by model + status (kaori_ai_calls_total)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["sli", "obs-020", "p15-s11"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "title": "Kaori — SLI Overview",
  "uid": "kaori-sli-overview",
  "version": 1
}

        <mxCell id="s3" value="Bước 3 Làm sạch dữ liệu (6 quy tắc, có nhật ký quyết định)" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="560" y="1000" width="210" height="60" as="geometry"/></mxCell>
        <mxCell id="s4" value="Bước 4 Chọn AI: Qwen nội bộ / API ngoài (Claude·GPT) — cần đồng ý gửi dữ liệu ra ngoài" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ede7f6;strokeColor=#5e35b1;" vertex="1" parent="1"><mxGeometry x="560" y="1090" width="210" height="70" as="geometry"/></mxCell>

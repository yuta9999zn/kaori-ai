<mxfile host="app.diagrams.net">
  <diagram name="Quy trinh demo Kaori v2" id="kaori-demo-v2">
    <mxGraphModel dx="1200" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="org" value="Cơ cấu tổ chức" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="40" y="40" width="160" height="50" as="geometry"/></mxCell>
        <mxCell id="dept" value="Phòng ban&#10;(8 phòng + mô tả nghiệp vụ)" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="330" y="40" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="biz" value="Nghiệp vụ phòng ban" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="660" y="40" width="180" height="50" as="geometry"/></mxCell>
        <mxCell id="tmpl" value="Gắn MẪU TÀI LIỆU vào folder nghiệp vụ trong Kho (folder-as-page) — file tải vào thừa hưởng form thuộc tính" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="310" y="140" width="220" height="70" as="geometry"/></mxCell>

        <mxCell id="rag" value="RAG — thước đo quy chuẩn &amp; tri thức doanh nghiệp (nạp QĐ-01, SOP-02…)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3d6;strokeColor=#c9a227;" vertex="1" parent="1"><mxGeometry x="20" y="200" width="210" height="70" as="geometry"/></mxCell>
        <mxCell id="ragd" value="Đối chiếu quy định/SOP tự động + hỏi đáp có trích dẫn — thiếu căn cứ → AI TỪ CHỐI (không bịa)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff3d6;strokeColor=#c9a227;" vertex="1" parent="1"><mxGeometry x="20" y="330" width="210" height="90" as="geometry"/></mxCell>

        <mxCell id="tree" value="Cây tài liệu theo quy trình nghiệp vụ" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="560" y="150" width="170" height="60" as="geometry"/></mxCell>
        <mxCell id="bpmn" value="BPMN (chuẩn công nghiệp, tải .bpmn)" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="760" y="150" width="140" height="60" as="geometry"/></mxCell>
        <mxCell id="wf" value="Workflow quy trình nghiệp vụ (15 bước · cổng duyệt &gt; 50 triệu)" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="930" y="150" width="160" height="70" as="geometry"/></mxCell>

        <mxCell id="up" value="Upload tài liệu theo bước" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="560" y="270" width="170" height="50" as="geometry"/></mxCell>
        <mxCell id="dlg" value="Dialog: Lưu vào Kho tài liệu?" style="rhombus;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="545" y="360" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="save" value="LƯU: folder TRÙNG TÊN workflow — có sẵn thì dùng, chưa có tự tạo (ngày thêm/sửa · lọc · tìm kiếm)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;" vertex="1" parent="1"><mxGeometry x="400" y="480" width="210" height="80" as="geometry"/></mxCell>
        <mxCell id="nosave" value="KHÔNG lưu — chỉ nộp vào bước" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="680" y="480" width="170" height="60" as="geometry"/></mxCell>

        <mxCell id="cleanq" value="Kiểm tra sạch (AI chấm sạch/bẩn, có lý do)" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="560" y="600" width="180" height="60" as="geometry"/></mxCell>
        <mxCell id="okgo" value="SẠCH → Phân tích ngay" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="400" y="710" width="160" height="50" as="geometry"/></mxCell>
        <mxCell id="bad" value="CHƯA SẠCH → hệ đề nghị đi 5 bước làm sạch" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="640" y="710" width="200" height="60" as="geometry"/></mxCell>

        <mxCell id="s1" value="Bước 1 Upload — hệ TỰ hoàn tất (file đã có, chống trùng SHA-256)" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1"><mxGeometry x="560" y="820" width="210" height="60" as="geometry"/></mxCell>
